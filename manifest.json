{
  "manifest_version": 3,
  "name": "YouTube Auto Skip Promotions",
  "version": "1.0",
  "description": "Automatically clicks YouTube's built-in skip button for paid promotions in videos.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
